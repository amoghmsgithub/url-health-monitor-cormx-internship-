@{
    ViewData["Title"] = "User Manual";
}

<div class="container manual-page">

    <div class="user-manual-wrapper">

        <h1 class="user-manual-title">User Manual</h1>
        <p class="user-manual-subtitle">
            Everything you need to use CORMX effectively
        </p>

        <div class="manual-card">
            <h4>1. Adding a URL</h4>
            <ul>
                <li>Go to <strong>Monitored URLs</strong></li>
                <li>Click <strong>Create</strong></li>
                <li>Enter URL name and address</li>
                <li>Select interval (30 / 40 / 50 seconds)</li>
                <li>Click <strong>Save</strong></li>
            </ul>
        </div>

        <div class="manual-card">
            <h4>2. Health Status</h4>
            <ul>
                <li>
                    <span class="status-pill status-up">UP</span>
                    URL is reachable
                </li>
                <li>
                    <span class="status-pill status-down">DOWN</span>
                    URL is unreachable
                </li>
            </ul>
        </div>

        <div class="manual-card">
            <h4>3. Automatic Checks</h4>
            <ul>
                <li>URLs are checked automatically</li>
                <li>Status updates every interval</li>
                <li>Email alerts are sent if a URL goes down</li>
            </ul>
        </div>

        <div class="manual-card">
            <h4>4. Edit / Delete</h4>
            <ul>
                <li>Edit URL or interval using <strong>Edit</strong></li>
                <li>Stop monitoring using <strong>Delete</strong></li>
            </ul>
        </div>

    </div>

</div>
